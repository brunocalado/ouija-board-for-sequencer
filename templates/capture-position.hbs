<div class="ouija-dialog">

  <div class="form-group">
    <label>Current Token Position</label>
    <div class="form-fields ouija-capture-fields">
      <label>X</label>
      <input id="ouija-capture-x" class="ouija-capture-input" type="number" step="0.01" value="{{currentX}}">
      <label>Y</label>
      <input id="ouija-capture-y" class="ouija-capture-input" type="number" step="0.01" value="{{currentY}}">
    </div>
    <p class="hint">Values auto-filled from the selected token. You can adjust manually.</p>
  </div>

  <div class="form-group">
    <label>Save As Position Key</label>
    <div class="form-fields">
      <select id="ouija-capture-key">
        <option value="">— Select a position key —</option>
        {{#each mapOptions}}
          <option value="{{this.key}}">{{this.label}}</option>
        {{/each}}
      </select>
    </div>
    <p class="hint">Select the map key whose coordinates you want to overwrite with the values above.</p>
  </div>

</div>
