<div style="display:flex; flex-direction:column; gap:10px; padding: 8px 0;">

  <div class="form-group">
    <label>Current Token Position</label>
    <div class="form-fields" style="gap:8px;">
      <label>X</label>
      <input id="ouija-capture-x" type="number" step="0.01" value="{{currentX}}" style="width:100px;">
      <label>Y</label>
      <input id="ouija-capture-y" type="number" step="0.01" value="{{currentY}}" style="width:100px;">
    </div>
    <p class="hint">Values auto-filled from the selected token. You can adjust manually.</p>
  </div>

  <div class="form-group">
    <label>Save As Position Key</label>
    <div class="form-fields">
      <select id="ouija-capture-key" style="width:100%;">
        <option value="">— Select a position key —</option>
        {{#each mapKeys}}
          <option value="{{this}}">{{this}}</option>
        {{/each}}
      </select>
    </div>
    <p class="hint">Select the map key whose coordinates you want to overwrite with the values above.</p>
  </div>

</div>
