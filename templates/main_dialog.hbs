<div class="ouija-dialog">

  <!-- Section: Message — radio picks between free text, Yes, or No -->
  <div class="ouija-section">
    <p class="ouija-section-title">Message</p>
    <div class="ouija-radio-group">
      <label><input type="radio" id="position_message" name="extra_position" value="message" checked> Message</label>
      <label><input type="radio" id="position_yes" name="extra_position" value="position_yes"> Yes</label>
      <label><input type="radio" id="position_no" name="extra_position" value="position_no"> No</label>
    </div>
    <textarea name="text" id="message" rows="3" placeholder="Insert your text here. ex: wasp"></textarea>
  </div>

  <!-- Section: Position — custom named symbol positions defined in settings -->
  <div class="ouija-section">
    <p class="ouija-section-title">Position</p>
    <div class="form-group">
      <label>Custom Position:</label>
      <div class="form-fields">
        <select id="custom_position" name="custom_position">
          <option value="custom_position_choose">Choose</option>
          <option value="position_01">{{customPositionLabel1}}</option>
          <option value="position_02">{{customPositionLabel2}}</option>
          <option value="position_03">{{customPositionLabel3}}</option>
          <option value="position_04">{{customPositionLabel4}}</option>
          <option value="position_05">{{customPositionLabel5}}</option>
          <option value="position_06">{{customPositionLabel6}}</option>
          <option value="position_07">{{customPositionLabel7}}</option>
          <option value="position_08">{{customPositionLabel8}}</option>
          <option value="position_09">{{customPositionLabel9}}</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Section: Settings — movement behaviour and timing -->
  <div class="ouija-section">
    <p class="ouija-section-title">Settings</p>
    <div class="form-group">
      <label>Move Type:</label>
      <div class="form-fields">
        <select id="movetype" name="movetype">
          <option value="moveType1">Standard</option>
          <option value="moveType2">No Sound / No Animation</option>
          <option value="moveType3">Animation at End</option>
        </select>
      </div>
    </div>
    <div class="ouija-row">
      <div class="form-group">
        <label>Delay Min:</label>
        <div class="form-fields">
          <input id="extraTimeMin" type="number" name="extraTimeMin" value="{{extraTimeMinDefault}}" min="1" max="10000" required>
        </div>
      </div>
      <div class="form-group">
        <label>Delay Max:</label>
        <div class="form-fields">
          <input id="extraTimeMax" type="number" name="extraTimeMax" value="{{extraTimeMaxDefault}}" min="1" max="10000" required>
        </div>
      </div>
    </div>
    <div class="form-group">
      <label>Move Speed <span class="hint">(higher number is slower)</span>:</label>
      <div class="form-fields">
        <input id="moveSpeed" type="number" name="moveSpeed" value="{{moveSpeedDefault}}" min="500" max="3000" required>
      </div>
    </div>
  </div>

</div>
