<div class="ouija-dialog">
  <div class="ouija-section">
    <p class="ouija-section-title">Sound Settings</p>

    {{!-- Move Sound --}}
    <div class="form-group ouija-form-spaced">
      <label for="ouija-sound-move">Move Sound</label>
      <p class="notes">This sound is played each movement.</p>
      <div class="ouija-file-row">
        <input type="text" id="ouija-sound-move" value="{{moveSoundPath}}" />
        <button type="button" class="ouija-browse-btn" data-target="ouija-sound-move" data-type="audio">
          <i class="fas fa-file-audio"></i>
        </button>
      </div>
    </div>

    {{!-- Move Sound Volume --}}
    <div class="form-group ouija-form-spaced">
      <label for="ouija-volume-move">Move Sound Volume</label>
      <p class="notes">Use 0.1 for 10%, 0.6 for 60%, etc.</p>
      <div class="ouija-range-row">
        <input type="range" id="ouija-volume-move" min="0" max="1" step="0.1" value="{{moveSoundVolume}}" />
        <span class="ouija-range-display" id="ouija-volume-move-display">{{moveSoundVolume}}</span>
      </div>
    </div>

    <hr class="ouija-divider" />

    {{!-- Use End Sound Toggle --}}
    <div class="form-group ouija-form-spaced">
      <div class="ouija-checkbox-row">
        <input type="checkbox" id="ouija-use-end-sound" {{#if useEndSound}}checked{{/if}} />
        <label for="ouija-use-end-sound" class="ouija-checkbox-label">Use End Sound</label>
      </div>
      <p class="notes">When enabled, the end sound replaces the normal move sound.</p>
    </div>

    {{!-- End Sound Section (toggled by checkbox) --}}
    <div id="ouija-end-sound-section">

      {{!-- End Move Sound --}}
      <div class="form-group ouija-form-spaced">
        <label for="ouija-sound-end">End Move Sound</label>
        <p class="notes">This sound is played instead of the normal move sound.</p>
        <div class="ouija-file-row">
          <input type="text" id="ouija-sound-end" value="{{endSoundPath}}" />
          <button type="button" class="ouija-browse-btn" data-target="ouija-sound-end" data-type="audio">
            <i class="fas fa-file-audio"></i>
          </button>
        </div>
      </div>

      {{!-- End Move Sound Volume --}}
      <div class="form-group">
        <label for="ouija-volume-end">End Move Sound Volume</label>
        <p class="notes">Use 0.1 for 10%, 0.6 for 60%, etc.</p>
        <div class="ouija-range-row">
          <input type="range" id="ouija-volume-end" min="0" max="1" step="0.1" value="{{endSoundVolume}}" />
          <span class="ouija-range-display" id="ouija-volume-end-display">{{endSoundVolume}}</span>
        </div>
      </div>

    </div>

  </div>
</div>
